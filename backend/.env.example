# Database URL (Render automatically sets this when you add PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/database

# Hugging Face API Configuration
HF_API_URL=https://api-inference.huggingface.co/models/muhaba23/student-sentiment-model
HF_API_TOKEN=your_hugging_face_token_here

# Email Configuration (optional - for password reset emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password
